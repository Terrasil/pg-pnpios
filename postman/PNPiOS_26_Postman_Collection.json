              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "currencies",
                "rates"
              ],
              "query": [
                {
                  "key": "base",
                  "value": "{{baseCurrency}}"
                }
              ]
            },
            "description": "Najważniejszy endpoint do testowania pobierania kursów walut przez backend."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status 200', function () { pm.response.to.have.status(200); });",
                  "pm.test('Has base field', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json).to.have.property('base');",
                  "});",
                  "pm.test('Has items array', function () {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.items).to.be.an('array');",
                  "});"
                ]
              }
            }
          ]
        },
        {
