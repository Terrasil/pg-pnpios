  "item": [
    {
      "name": "Books",
      "description": "Endpointy związane z wyszukiwaniem książek, szczegółami książki i ofertami cenowymi.",
      "item": [
        {
          "name": "Search books",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Accept",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/v1/books/search?q={{book_query}}&page={{page}}&size={{size}}&currency={{currency}}",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "v1",
                "books",
                "search"
              ],
              "query": [
                {
                  "key": "q",
                  "value": "{{book_query}}",
                  "description": "Fraza wyszukiwania, np. hobbit"
                },
                {
                  "key": "page",
                  "value": "{{page}}",
                  "description": "Numer strony, liczony od 0"
                },
                {
                  "key": "size",
                  "value": "{{size}}",
                  "description": "Liczba elementów na stronę"
                },
                {
                  "key": "currency",
                  "value": "{{currency}}",
                  "description": "Waluta docelowa cen, np. PLN, USD, EUR"
                }
              ]
            },
            "description": "Wyszukuje książki po frazie. Odpowiedź zawiera listę `BookSearchItemDTO`, liczbę ofert oraz zakres cen w wybranej walucie."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 2xx', function () {",
                  "    pm.expect(pm.response.code).to.be.within(200, 299);",
                  "});",
                  "",
                  "pm.test('Response is JSON', function () {",
                  "    pm.response.to.have.header('Content-Type');",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test('Search books response has items array', function () {",
                  "    pm.expect(json).to.have.property('items');",
                  "    pm.expect(json.items).to.be.an('array');",
                  "});",
                  "if (json.items && json.items.length > 0 && json.items[0].id) {",
                  "    pm.environment.set('bookId', json.items[0].id);",
                  "}"
                ]
              }
            }
          ]
        },
